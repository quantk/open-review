{
  "name": "open-review",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Local MR-like review loop for opencode agent changes.",
  "main": "./dist/index.js",
  "files": [
    "index.js",
    "dist",
    "src",
    "commands",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:server",
    "build:server": "esbuild src/runtime.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js",
    "build:ui": "node scripts/build-ui.mjs",
    "prebuild:server": "npm run build:ui",
    "check": "node --check src/runtime.ts",
    "smoke": "node src/runtime.ts --local-review-server",
    "test": "npm run build:ui && node --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.ui.json"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.14.30"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "0.27.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/quantk/open-review.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "review",
    "diff",
    "local-review"
  ],
  "license": "MIT"
}
